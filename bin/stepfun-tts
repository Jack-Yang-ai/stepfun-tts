#!/usr/bin/env node

/**
 * StepFun TTS Provider for OpenClaw
 *
 * Text → StepFun API (response_format: opus) → Opus file + duration
 *
 * Zero external dependencies. No ffmpeg needed.
 *
 * Input:  { text, config? }
 * Output: { audioPath, format, duration }
 */

const fs = require('fs');
const path = require('path');
const https = require('https');
const { execSync } = require('child_process');

const defaults = {
  apiKey: process.env.STEPFUN_API_KEY || '',
  baseUrl: process.env.STEPFUN_BASE_URL || 'https://api.stepfun.com/v1',
  model: process.env.STEPFUN_TTS_MODEL || 'step-tts-2',
  voice: process.env.STEPFUN_TTS_VOICE || 'yuanqishaonv',
  format: process.env.STEPFUN_TTS_FORMAT || 'opus',
  timeoutMs: parseInt(process.env.STEPFUN_TIMEOUT_MS || '30000', 10),
};

// ─── StepFun TTS API ────────────────────────────────────────────
function callAPI(text, ov = {}) {
  return new Promise((resolve, reject) => {
    const apiKey = ov.apiKey || defaults.apiKey;
    if (!apiKey) { reject(new Error('STEPFUN_API_KEY not set')); return; }

    const fmt = ov.format || defaults.format;
    const payload = JSON.stringify({
      model: ov.model || defaults.model,
      voice: ov.voice || defaults.voice,
      input: text,
      response_format: fmt,
    });

    const baseUrl = (ov.baseUrl || defaults.baseUrl).replace(/\/+$/, '');
    const url = new URL(`${baseUrl}/audio/speech`);

    const req = https.request({
      hostname: url.hostname,
      port: url.port || 443,
      path: url.pathname,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${apiKey}`,
        'Content-Length': Buffer.byteLength(payload),
      },
      timeout: ov.timeoutMs || defaults.timeoutMs,
    }, (res) => {
      const chunks = [];
      res.on('data', (c) => chunks.push(c));
      res.on('end', () => {
        if (res.statusCode !== 200) {
          reject(new Error(`HTTP ${res.statusCode}: ${Buffer.concat(chunks).toString('utf8').slice(0, 300)}`));
          return;
        }
        resolve(Buffer.concat(chunks));
      });
    });
    req.on('error', (e) => reject(new Error(`Request failed: ${e.message}`)));
    req.on('timeout', () => { req.destroy(); reject(new Error('Request timed out')); });
    req.write(payload);
    req.end();
  });
}

// ─── Opus duration (parse Ogg headers, no ffmpeg) ───────────────
function getOpusDuration(buf) {
  // Ogg Opus: find sample rate from OpusHead, then count granule positions
  // Fast method: find last Ogg page's granule position
  try {
    // OpusHead: sample rate at bytes 12-15 (little-endian)
    let sampleRate = 48000; // Opus default
    for (let i = 0; i < buf.length - 4; i++) {
      if (buf[i] === 0x4F && buf[i+1] === 0x67 && buf[i+2] === 0x67 && buf[i+3] === 0x53) {
        // OggS page found — granule position at offset +6 (8 bytes, LE)
        // We want the LAST page's granule
      }
    }
    // Simpler: use last OggS page granule position
    let lastGranule = 0n;
    let pos = buf.length - 4;
    while (pos >= 0) {
      if (buf[pos] === 0x4F && buf[pos+1] === 0x67 && buf[pos+2] === 0x67 && buf[pos+3] === 0x53) {
        // granule position: 8 bytes at offset 6
        lastGranule = buf.readBigUInt64LE(pos + 6);
        break;
      }
      pos--;
    }
    if (lastGranule > 0n) {
      return Math.ceil(Number(lastGranule) / sampleRate);
    }
  } catch {}
  // Fallback: try ffmpeg/ffprobe if available
  return 0;
}

function getDurationFfmpeg(file) {
  try {
    const ffmpeg = process.env.FFMPEG_PATH || 'ffmpeg';
    const out = execSync(`"${ffmpeg}" -i "${file}" -f null - 2>&1 | grep "time=" | tail -1`, {
      encoding: 'utf8', shell: true, timeout: 5000,
    });
    const m = out.match(/time=(\d+):(\d+):([\d.]+)/);
    if (m) return Math.ceil(+m[1] * 3600 + +m[2] * 60 + parseFloat(m[3]));
  } catch {}
  return 0;
}

// ─── Main ───────────────────────────────────────────────────────
(async () => {
  let raw = '';
  process.stdin.setEncoding('utf8');
  process.stdin.on('data', (c) => (raw += c));
  process.stdin.on('end', async () => {
    try {
      const { text, config: ov = {} } = JSON.parse(raw);
      if (!text || typeof text !== 'string') throw new Error('Missing "text"');

      const fmt = ov.format || defaults.format;
      const ext = fmt === 'opus' ? '.opus' : fmt === 'wav' ? '.wav' : `.${fmt}`;

      // Call API with response_format directly — no conversion needed
      const buf = await callAPI(text, ov);

      const outDir = process.env.OPENCLAW_TTS_OUT_DIR || '/tmp/openclaw/tts';
      fs.mkdirSync(outDir, { recursive: true });
      const tag = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
      const outPath = path.join(outDir, `stepfun-${tag}${ext}`);
      fs.writeFileSync(outPath, buf);

      // Get duration
      let duration = 0;
      if (fmt === 'opus') {
        duration = getOpusDuration(buf);
      }
      if (duration === 0) {
        duration = getDurationFfmpeg(outPath);
      }

      process.stdout.write(JSON.stringify({ audioPath: outPath, format: fmt, duration }) + '\n');
    } catch (e) {
      process.stderr.write(e.message + '\n');
      process.exit(1);
    }
  });
})();
